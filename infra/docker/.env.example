# SMTP settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_USE_TLS=true

# Email defaults
EMAIL_FROM=${SMTP_USER}
EMAIL_TO=notify@example.com

# DB: leave as file in apps/api (mounted by compose)
# For production consider using an external DB instead of SQLite
