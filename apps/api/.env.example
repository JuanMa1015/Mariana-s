# Configuración SMTP (ejemplo)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_USE_TLS=true

# Email defaults
EMAIL_FROM=${SMTP_USER}
EMAIL_TO=notify@example.com

# Token para invocar endpoints protegidos desde CI/CD (no comitear secretos reales)
API_TOKEN=un_token_secreto_largo_aqui
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=usuario@tu-dominio.com
SMTP_PASSWORD=tu-password
SMTP_USE_TLS=true
EMAIL_FROM=usuario@tu-dominio.com
EMAIL_TO=destinatario1@tu-dominio.com,destinatario2@tu-dominio.com