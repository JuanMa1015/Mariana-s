# Configuración SMTP (ejemplo)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASSWORD=YOUR_SMTP_PASSWORD
SMTP_USE_TLS=true

# Email defaults
EMAIL_FROM=${SMTP_USER}
EMAIL_TO=notify@example.com

# Token para invocar endpoints protegidos desde CI/CD (no comitear secretos reales)
API_TOKEN=un_token_secreto_largo_aqui

# Base de datos Neon PostgreSQL
# Pega aquí la cadena que te da Neon desde Connection string.
# Ejemplo:
# DATABASE_URL=postgresql://usuario:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://usuario:password@ep-xxxxx.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require